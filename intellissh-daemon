class DaemonServer:
    def __init__(self, config):
        self.config = config
        self.running = False
        # Load focused context files at startup (bypasses RAG when --context is set)
        self.context_text = _load_context_files(
            CONTEXT_NAME, config.get("context_dir", str(BASE_DIR / "contexts"))
        )
        context_loaded = (not CONTEXT_NAME) or bool(self.context_text)
        self.engine = SituationEngine(config, context_loaded=context_loaded)

    def start(self):
        # Clean up old socket
        if SOCKET_PATH.exists():
            SOCKET_PATH.unlink()
        SOCKET_PATH.parent.mkdir(parents=True, exist_ok=True)

        self.sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.sock.bind(str(SOCKET_PATH))
        self.sock.listen(10)
        self.sock.settimeout(1.0)
        self.running = True

        # Write PID
        PID_PATH.write_text(str(os.getpid()))

        # Start web dashboard
        web_port = self.config.get("web_port", 8033)
        try:
            web_server, web_port = start_web_server(self.engine, web_port)
            print(f"[intellissh-daemon] Dashboard: http://127.0.0.1:{web_port}")
        except OSError as e:
            print(f"[intellissh-daemon] Dashboard failed to start: {e}")

        if CONTEXT_NAME:
            mode_label = f"[context: {CONTEXT_NAME}]"
        elif PROFILE:
            mode_label = f"[profile: {PROFILE}]"
        else:
            mode_label = "[default]"
        print(f"[intellissh-daemon] Listening on {SOCKET_PATH}")
        print(f"[intellissh-daemon] Model: {self.config['model']}")
        print(f"[intellissh-daemon] PID: {os.getpid()} {mode_label}")
        if self.context_text:
            print(f"[intellissh-daemon] Context mode: direct file injection (no RAG)")
        elif CONTEXT_NAME:
            print(f"[intellissh-daemon] !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
            print(f"[intellissh-daemon] WARNING: --context '{CONTEXT_NAME}' was set")
            print(f"[intellissh-daemon] but NO matching files found in contexts dir.")
            print(f"[intellissh-daemon] Pattern searched: *{CONTEXT_NAME}*")
            print(f"[intellissh-daemon] Falling back to RAG — context NOT loaded.")
            print(f"[intellissh-daemon] !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
        else:
            print(f"[intellissh-daemon] Context mode: RAG retrieval")

        while self.running:
            try:
                conn, _ = self.sock.accept()
                t = threading.Thread(target=self._handle_client, args=(conn,), daemon=True)
                t.start()
            except socket.timeout:
                continue
            except OSError:
                break

    def stop(self):
        self.running = False
        self.engine._save_state()
        try:
            self.sock.close()
        except Exception:
            pass
        if SOCKET_PATH.exists():
            SOCKET_PATH.unlink()
        if PID_PATH.exists():
            PID_PATH.unlink()
        if DASHBOARD_PORT_FILE.exists():
            DASHBOARD_PORT_FILE.unlink()
        print("\n[intellissh-daemon] Stopped.")

    def _handle_client(self, conn):
        try:
            buf = b""
            while True:
                data = conn.recv(65536)
                if not data:
                    break
                buf += data
                while b"\n" in buf:
                    line, buf = buf.split(b"\n", 1)
                    if line.strip():
                        self._process_message(conn, line.decode("utf-8", errors="replace"))
        except (ConnectionResetError, BrokenPipeError):
            pass
        finally:
            conn.close()

    def _process_message(self, conn, raw):
        try:
            msg = json.loads(raw)
        except json.JSONDecodeError:
            self._send(conn, {"type": "error", "text": "Invalid JSON"})
            return

        msg_type = msg.get("type", "")
        session = msg.get("session", "unknown")

        if msg_type == "transcript":
            cmd = msg.get("cmd", "")
            output = msg.get("output", "")
            self.engine.add_transcript(session, cmd, output)

            # Auto-detect
            if self.config.get("auto_detect", True) and self.engine.should_auto_detect(session):
                findings = check_auto_detect(output)
                if findings:
                    for desc, sample in findings:
                        self.engine.add_event(session, f"{desc}: {sample}")
                    # Ack immediately so the terminal isn't blocked waiting for LLM
                    self._send(conn, {"type": "event_queued", "count": len(findings)})
                    # Run analysis in background; result goes to dashboard only
                    def _run_detect(session=session, findings=findings):
                        aid = self.engine.begin_analysis(session, "auto-detect")
                        try:
                            text, suggestions = run_auto_detect_analysis(
                                self.config, self.engine, session, findings,
                                self.context_text)
                            self.engine.add_ai_analysis(session, "auto-detect", text, suggestions)
                        except Exception as e:
                            self.engine.add_ai_analysis(session, "auto-detect",
                                                        f"[Auto-detect error: {e}]", [])
                        finally:
                            self.engine.end_analysis(aid)
                    threading.Thread(target=_run_detect, daemon=True).start()
                else:
                    self._send(conn, {"type": "ack"})
            else:
                self._send(conn, {"type": "ack"})

        elif msg_type == "analyze":
            request = msg.get("request", None)
            trigger = f"hotkey: {request}" if request else "hotkey"
            aid = self.engine.begin_analysis(session, trigger)
            try:
                text, suggestions = run_analysis(
                    self.config, self.engine, session, request,
                    self.context_text)
                self.engine.add_ai_analysis(session, trigger, text, suggestions)
                self._send(conn, {
                    "type": "response",
                    "text": text,
                    "suggestions": suggestions,
                })
            except Exception as e:
                self._send(conn, {"type": "error", "text": f"Analysis error: {e}"})
            finally:
                self.engine.end_analysis(aid)

        elif msg_type == "status":
            situation = self.engine.build_situation_summary()
            sessions = list(self.engine.sessions.keys())
            self._send(conn, {
                "type": "status",
                "sessions": sessions,
                "situation": situation,
            })

        elif msg_type == "sessions":
            self._send(conn, {
                "type": "sessions",
                "sessions": {k: v for k, v in self.engine.sessions.items()},
            })

        elif msg_type == "flush":
            self.engine.flush()
            self._send(conn, {"type": "ack", "text": "State flushed."})

        else:
            self._send(conn, {"type": "error", "text": f"Unknown message type: {msg_type}"})

    def _send(self, conn, obj):
        try:
            conn.sendall(json.dumps(obj).encode("utf-8") + b"\n")
        except (BrokenPipeError, ConnectionResetError):
            pass


