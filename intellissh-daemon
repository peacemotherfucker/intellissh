#!/usr/bin/env python3
"""
intellissh-daemon — Shared situation-awareness daemon for IntelliSSH.

Runs in the background, accumulates terminal transcripts from all connected
PTY wrapper sessions via a UNIX domain socket. Maintains a rolling situation
model, detects interesting security events, and responds to analysis requests.

Protocol (JSON over UNIX socket, newline-delimited):
  Client → Daemon:
    {"type": "transcript", "session": "ids-sensor", "cmd": "...", "output": "..."}
    {"type": "analyze", "session": "ids-sensor", "request": "free-form question"}
    {"type": "analyze", "session": "ids-sensor"}   # auto-analyze last output
    {"type": "status"}                               # get current situation
    {"type": "sessions"}                             # list active sessions
    {"type": "flush"}                                # reset all state (clean sheet)
  Daemon → Client:
    {"type": "response", "text": "...", "suggestions": [...]}
    {"type": "alert", "text": "...", "suggestions": [...]}
    {"type": "status", "sessions": [...], "situation": "..."}
"""

