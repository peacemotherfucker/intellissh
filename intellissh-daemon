SOCKET_PATH = BASE_DIR / "daemon.sock"
PID_PATH = BASE_DIR / "daemon.pid"
INDEX_HASH_FILE = BASE_DIR / ".index_hash"
COLLECTION_NAME = "intellissh_contexts"
LOG_DIR = BASE_DIR / "logs"
STATE_PATH = BASE_DIR / "state.json"
DASHBOARD_PORT_FILE = BASE_DIR / "dashboard.port"

def _load_context_files(context_name, ctx_dir):
    """Load all .md files matching *context_name*. Returns concatenated text.

    Searches the global ~/.intellissh/contexts first, then ctx_dir if different.
    Context files are a shared library; profiles only isolate state.
    """
    if not context_name:
        return ""
    global_ctx = Path("~/.intellissh/contexts").expanduser()
    search_dirs = [global_ctx]
    extra = Path(ctx_dir).expanduser()
    if extra != global_ctx and extra.exists():
        search_dirs.append(extra)

    pattern = f"*{context_name}*"
    seen = set()
    matches = []
    for d in search_dirs:
        for f in sorted(d.rglob(pattern)):
            if f not in seen:
                seen.add(f)
                matches.append(f)

    if not matches:
        print(f"[intellissh-daemon] Warning: no files matching '*{context_name}*' found")
        return ""
    parts = []
    for f in matches:
        try:
            parts.append(f"### {f.name}\n\n{f.read_text(encoding='utf-8')}")
            print(f"[intellissh-daemon] Loaded context: {f.name}")
        except OSError as e:
            print(f"[intellissh-daemon] Warning: could not read {f}: {e}")
    return "\n\n---\n\n".join(parts)


