# ─── Profile & paths ─────────────────────────────────────────────────────────

def _resolve_base_dir():
    # --context takes precedence over --profile for isolation
    context = os.environ.get("INTELLISSH_CONTEXT", "").strip()
    profile = os.environ.get("INTELLISSH_PROFILE", "").strip()
    isolation = context or profile or ""
    if not isolation:
        return Path("~/.intellissh").expanduser(), None, None
    safe = "".join(c for c in isolation if c.isalnum() or c in "_-")[:32]
    return Path(f"~/.intellissh/profiles/{safe}").expanduser(), safe, context or None

BASE_DIR, PROFILE, CONTEXT_NAME = _resolve_base_dir()
