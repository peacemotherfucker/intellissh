function esc(s) {
  if (!s) return '';
  var d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

/* Only update innerHTML if content actually changed — preserves scroll and text selection */
function safeUpdate(id, html) {
  var el = document.getElementById(id);
  if (el && el.innerHTML !== html) {
    el.innerHTML = html;
  }
}

function render(d) {
  if (!d) return;

  document.getElementById('start').textContent = d.start_time || '--';
  document.getElementById('now').textContent = d.now || '--';
  var ctx = d.context || 'default';
  document.getElementById('ctx-label').textContent =
    ctx === 'default' ? 'SITUATION DASHBOARD' : ctx.toUpperCase() + ' — SITUATION DASHBOARD';
  var warn = document.getElementById('ctx-warning');
  var warnMsg = document.getElementById('ctx-warning-msg');
  if (d.context_warning) {
    warn.style.display = 'block';
    warnMsg.textContent = 'No files matching "*' + ctx + '*" were found. AI is answering from general knowledge only — system documentation is NOT loaded. Check your context filename and restart the daemon.';
  } else {
    warn.style.display = 'none';
  }

  var t = document.getElementById('threat');
  if (t.textContent !== d.threat_level) {
    t.textContent = d.threat_level;
    t.className = 'threat-badge threat-' + d.threat_level;
  }

  document.getElementById('total-cmds').textContent = d.total_commands || 0;
  var sess = d.sessions || {};
  var sk = Object.keys(sess);
  document.getElementById('total-sessions').textContent = sk.length;
  document.getElementById('total-iocs').textContent = (d.iocs || []).length;

  var sh = '';
  if (sk.length === 0) { sh = '<div class="empty">No sessions yet</div>'; }
  else { sk.forEach(function(k) { var s = sess[k]; sh += '<div class="session-item"><span class="session-name">' + esc(k) + '</span><br><span class="session-meta">' + s.cmd_count + ' cmds &middot; last: ' + (s.last_active || '?') + '</span></div>'; }); }
  safeUpdate('sessions', sh);

  var ih = '';
  if (!d.iocs || d.iocs.length === 0) { ih = '<div class="empty">None detected</div>'; }
  else { d.iocs.forEach(function(i) { var tc = (i.type||'').replace(':',''); ih += '<div class="ioc-item"><span class="ioc-value" title="' + esc(i.value) + '">' + esc(i.value) + '</span><span class="ioc-type ioc-type-' + esc(tc) + '">' + esc(i.type||'') + '</span><span class="ioc-count">' + i.count + 'x</span></div>'; }); }
  safeUpdate('iocs', ih);

