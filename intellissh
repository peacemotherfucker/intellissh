    "auto_detect_debounce_secs": 5,
    "max_transcript_entries": 200,
    "log_sessions": True,
    "log_dir": str(BASE_DIR / "logs"),
}


def load_config():
    config = DEFAULT_CONFIG.copy()
    if CONFIG_PATH.exists():
        try:
            with open(CONFIG_PATH) as f:
                config.update(json.load(f))
        except (json.JSONDecodeError, IOError):
            pass
    return config


def save_config(config):
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_PATH, "w") as f:
        json.dump(config, f, indent=2)


# ─── Colors ──────────────────────────────────────────────────────────────────

class C:
    @staticmethod
    def _w(code, t):
        return f"\033[{code}m{t}\033[0m" if sys.stdout.isatty() else t
    @staticmethod
    def red(t):    return C._w("31", t)
    @staticmethod
    def green(t):  return C._w("32", t)
    @staticmethod
    def yellow(t): return C._w("33", t)
    @staticmethod
    def cyan(t):   return C._w("36", t)
    @staticmethod
    def bold(t):   return C._w("1", t)
    @staticmethod
    def dim(t):    return C._w("2", t)


# ─── Helpers ─────────────────────────────────────────────────────────────────

def _get_dashboard_url(base_dir=None):
    """Return the dashboard URL for a profile, reading the actual port from disk."""
    port_file = (base_dir or BASE_DIR) / "dashboard.port"
    if port_file.exists():
        try:
            return f"http://127.0.0.1:{port_file.read_text().strip()}"
        except OSError:
            pass
    config = load_config()
    return f"http://127.0.0.1:{config.get('web_port', 8033)}"


def _profile_is_running(base_dir):
    pid_path = base_dir / "daemon.pid"
    if not pid_path.exists():
        return False
    try:
        pid = int(pid_path.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, ProcessLookupError, PermissionError):
        pid_path.unlink(missing_ok=True)
        return False


# ─── Daemon management ──────────────────────────────────────────────────────

def is_daemon_running():
    if not PID_PATH.exists():
        return False
    try:
        pid = int(PID_PATH.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, ProcessLookupError, PermissionError):
        # Stale PID file
        PID_PATH.unlink(missing_ok=True)
        return False


def cmd_daemon(args):
    if args and args[0] == "stop":
        if is_daemon_running():
            pid = int(PID_PATH.read_text().strip())
            os.kill(pid, signal.SIGTERM)
            print(C.green("Daemon stopped."))
        else:
            print(C.yellow("Daemon is not running."))
        return

    if is_daemon_running():
        print(C.yellow("Daemon is already running."))
        print(C.dim(f"  PID: {PID_PATH.read_text().strip()}"))
        print(C.dim(f"  Socket: {SOCKET_PATH}"))
        return

    daemon_script = SCRIPT_DIR / "intellissh-daemon"
    if not daemon_script.exists():
        print(C.red(f"Cannot find: {daemon_script}"))
        sys.exit(1)

    # Check Ollama
    config = load_config()
    try:
        import requests
        r = requests.get(f"{config['ollama_url']}/api/tags", timeout=3)
        r.raise_for_status()
    except Exception:
        print(C.red("Cannot connect to Ollama."))
        print(C.dim(f"  Start it with: ollama serve"))
        sys.exit(1)

    child_env = {**os.environ,
                 "INTELLISSH_CONTEXT": CONTEXT or "",
                 "INTELLISSH_PROFILE": PROFILE or ""}

    if "--foreground" in args or "-f" in args:
        print(C.bold("Starting daemon in foreground..."))
        if PROFILE:
            print(C.dim(f"  Profile: {PROFILE}"))
        os.environ.update(child_env)
        os.execvp(sys.executable, [sys.executable, str(daemon_script)])
    else:
        # Start as background process
        print(C.bold("Starting daemon in background..."))
        BASE_DIR.mkdir(parents=True, exist_ok=True)
        log_file = BASE_DIR / "daemon.log"
        log_offset = log_file.stat().st_size if log_file.exists() else 0
        proc = subprocess.Popen(
            [sys.executable, str(daemon_script)],
            stdout=open(log_file, "a"),
            stderr=subprocess.STDOUT,
            start_new_session=True,
            env=child_env,
        )
        # Wait a moment and check it started
        import time
        time.sleep(1)
        if is_daemon_running():
            dashboard_url = _get_dashboard_url()
            if CONTEXT:
                print(C.dim(f"  Context:   {CONTEXT}"))
            elif PROFILE:
                print(C.dim(f"  Profile:   {PROFILE}"))
            print(C.green(f"  Daemon started (PID: {proc.pid})"))
            print(C.dim(f"  Dashboard: {dashboard_url}"))
            print(C.dim(f"  Log:       {log_file}"))
            # Check which context files were loaded (or warn if none)
            if CONTEXT:
                import time as _t
                _t.sleep(0.5)  # give daemon time to write its log
                try:
                    with open(log_file, "rb") as _lf:
                        _lf.seek(log_offset)
                        log_txt = _lf.read().decode("utf-8", errors="replace")
                    loaded = [ln.split("Loaded context: ", 1)[1].strip()
                              for ln in log_txt.splitlines()
                              if "Loaded context: " in ln]
                    if loaded:
                        print(C.green(f"  ✓ Context loaded ({len(loaded)} file(s)):"))
                        for fname in loaded:
                            print(C.dim(f"    {fname}"))
                    else:
                        print()
                        print(C.red(f"  ⚠ WARNING: no context files matched '*{CONTEXT}*'"))
                        print(C.red(f"    AI will answer from general knowledge only."))
                        print(C.yellow(f"    Check filenames in ~/.intellissh/contexts/"))
                        print(C.yellow(f"    then restart: intellissh --context {CONTEXT} daemon"))
                except OSError:
                    pass
        else:
            print(C.red(f"  Daemon failed to start. Check {log_file}"))


def cmd_wrap(args):
    if not args:
        print(C.red("Usage: intellissh wrap <command> [args...]"))
        print(C.dim("  intellissh wrap ssh analyst@10.0.1.20"))
        print(C.dim("  intellissh wrap bash"))
        sys.exit(1)

    if not is_daemon_running():
        print(C.yellow("⚠ Daemon not running. Starting it..."))
        cmd_daemon([])
        import time
        time.sleep(1)

    wrap_script = SCRIPT_DIR / "intellissh-wrap"
    if not wrap_script.exists():
        print(C.red(f"Cannot find: {wrap_script}"))
        sys.exit(1)

    os.environ["INTELLISSH_CONTEXT"] = CONTEXT or ""
    os.environ["INTELLISSH_PROFILE"] = PROFILE or ""
    os.execvp(sys.executable, [sys.executable, str(wrap_script)] + args)


def cmd_flush(args):
    if not is_daemon_running():
        print(C.red("Daemon is not running."))
        return

    import socket as sock
    try:
        s = sock.socket(sock.AF_UNIX, sock.SOCK_STREAM)
        s.connect(str(SOCKET_PATH))
        s.settimeout(5)
        s.sendall(json.dumps({"type": "flush"}).encode() + b"\n")
        data = s.recv(4096)
        s.close()
        resp = json.loads(data.decode())
        print(C.green("✓ " + resp.get("text", "State flushed.")))
    except Exception as e:
        print(C.red(f"Cannot connect to daemon: {e}"))


def cmd_status(args):
    if not is_daemon_running():
        print(C.red("Daemon is not running."))
        print(C.dim("  Start with: intellissh daemon"))
        return

    import socket as sock
    try:
        s = sock.socket(sock.AF_UNIX, sock.SOCK_STREAM)
        s.connect(str(SOCKET_PATH))
        s.settimeout(5)
        s.sendall(json.dumps({"type": "status"}).encode() + b"\n")
        data = s.recv(65536)
        s.close()
        resp = json.loads(data.decode())

        print(C.bold("\nIntelliSSH Status"))
        print(C.dim("─" * 40))
        pid = PID_PATH.read_text().strip() if PID_PATH.exists() else "?"
        if CONTEXT:
            print(f"  Context:    {C.cyan(CONTEXT)}")
        elif PROFILE:
            print(f"  Profile:    {C.cyan(PROFILE)}")
        else:
            print(f"  Context:    {C.dim('default')}")
        print(f"  Daemon PID: {C.green(pid)}")
        print(f"  Dashboard:  {C.cyan(_get_dashboard_url())}")
        sessions = resp.get("sessions", [])
        print(f"  Active sessions: {C.cyan(str(len(sessions)))}")
        for s in sessions:
            print(f"    • {s}")
        print()
        situation = resp.get("situation", "")
        if situation and situation != "(No activity yet)":
            print(C.bold("Situation:"))
            print(situation)
        else:
            print(C.dim("  No activity yet. Wrap a session: intellissh wrap ssh user@host"))
        print()
    except Exception as e:
        print(C.red(f"Cannot connect to daemon: {e}"))


