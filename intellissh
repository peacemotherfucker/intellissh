def cmd_init(args):
    config = load_config()
    ctx_dir = Path(config["context_dir"]).expanduser()

    if ctx_dir.exists() and any(ctx_dir.rglob("*")):
        print(C.yellow(f"Context directory exists: {ctx_dir}"))
        try:
            r = input("Overwrite examples? [y/N] > ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            return
