        print(C.green(f"  Created: {path}"))

    save_config(config)
    print(C.bold(f"\nEdit contexts in {ctx_dir}, then run: intellissh index"))


def cmd_index(args):
    """Build RAG index using intellissh-daemon's indexing logic."""
    config = load_config()
    ctx_dir = Path(config["context_dir"]).expanduser()
    force = "--force" in args or "-f" in args

    try:
        import requests as req
        import chromadb
    except ImportError:
        print(C.red("Missing: pip install requests chromadb"))
        sys.exit(1)

    # Check Ollama
    try:
        r = req.get(f"{config['ollama_url']}/api/tags", timeout=5)
        models = [m["name"] for m in r.json().get("models", [])]
    except Exception:
        print(C.red("Cannot connect to Ollama."))
        sys.exit(1)

    embed_model = config.get("embed_model", "nomic-embed-text")
    if not any(m == embed_model or m.startswith(embed_model + ":") for m in models):
        print(C.yellow(f"Pulling {embed_model}..."))
        subprocess.run(["ollama", "pull", embed_model], check=True)

    # Check if index is current
    hash_file = BASE_DIR / ".index_hash"
    current_hash = _hash_contexts(ctx_dir)

    if not force and hash_file.exists() and hash_file.read_text().strip() == current_hash:
        print(C.dim("Index is up to date. Use --force to rebuild."))
        return

    # Chunk documents
    all_chunks = []
    file_count = 0
    for ext in ("*.md", "*.yaml", "*.yml", "*.txt"):
        for f in sorted(ctx_dir.rglob(ext)):
            content = f.read_text(encoding="utf-8")
            rel = str(f.relative_to(ctx_dir))
            file_count += 1
            all_chunks.extend(_chunk(content, rel, config))

    if not all_chunks:
        print(C.yellow("No context files found."))
        return

    print(C.bold(f"Indexing {file_count} files → {len(all_chunks)} chunks"))

    # Build ChromaDB
    db_path = Path(config.get("db_dir", "~/.intellissh/vectordb")).expanduser()
    db_path.mkdir(parents=True, exist_ok=True)
    client = chromadb.PersistentClient(path=str(db_path))

    try:
        client.delete_collection("intellissh_contexts")
    except Exception:
        pass

    def embed_fn(texts):
        url = f"{config['ollama_url']}/api/embed"
        try:
            r = req.post(url, json={"model": embed_model, "input": texts}, timeout=120)
            r.raise_for_status()
            return r.json().get("embeddings", [])
        except req.HTTPError:
            results = []
            for t in texts:
                r2 = req.post(f"{config['ollama_url']}/api/embeddings",
                              json={"model": embed_model, "prompt": t}, timeout=120)
                r2.raise_for_status()
                results.append(r2.json().get("embedding", []))
            return results

    class EmbFn:
        name = "ollama-embed"
        def __call__(self, input):
            return embed_fn(input)

    collection = client.create_collection("intellissh_contexts", embedding_function=EmbFn(),
                                          metadata={"hnsw:space": "cosine"})

    batch_size = 20
    for i in range(0, len(all_chunks), batch_size):
        batch = all_chunks[i:i+batch_size]
        pct = int(min(i+batch_size, len(all_chunks)) / len(all_chunks) * 100)
        sys.stdout.write(f"\r  Embedding: {min(i+batch_size, len(all_chunks))}/{len(all_chunks)} ({pct}%)")
        sys.stdout.flush()
        collection.add(
            ids=[f"c_{i+j}" for j in range(len(batch))],
            documents=[c["text"] for c in batch],
            metadatas=[{"source": c["source"], "section": c["section"]} for c in batch])

    print(C.green(f"\r  Done: {len(all_chunks)} chunks from {file_count} files ✓         "))

    hash_file.parent.mkdir(parents=True, exist_ok=True)
    hash_file.write_text(current_hash)
    print(C.green("Index ready."))


def _hash_contexts(ctx_dir):
    h = hashlib.sha256()
    for ext in sorted(["*.md", "*.yaml", "*.yml", "*.txt"]):
        for f in sorted(ctx_dir.rglob(ext)):
            h.update(str(f).encode())
            h.update(f.read_bytes())
    return h.hexdigest()


def _chunk(text, source, config, chunk_size=None, overlap=None):
    cs = chunk_size or config.get("rag_chunk_size", 800)
    ov = overlap or config.get("rag_chunk_overlap", 100)
    chunks = []
    section = source
    lines = text.split("\n")
    cur, cur_len = [], 0
    for line in lines:
        s = line.strip()
        if s.startswith("#"):
            section = s.lstrip("#").strip()
        cur.append(line)
        cur_len += len(line) + 1
        if cur_len >= cs:
            chunks.append({"text": "\n".join(cur), "source": source, "section": section})
            keep, kl = [], 0
            for ol in reversed(cur):
                kl += len(ol) + 1
                keep.insert(0, ol)
                if kl >= ov:
                    break
            cur, cur_len = keep, kl
    if cur:
        t = "\n".join(cur)
        if t.strip():
            chunks.append({"text": t, "source": source, "section": section})
    return chunks


# ─── Ask (quick one-shot, no session) ───────────────────────────────────────

def _load_context_files(context_name, ctx_dir):
    """Find and load all .md files matching *context_name*.

    Searches the global ~/.intellissh/contexts first, then ctx_dir if different.
    Context files are a shared library; profiles only isolate state.
    """
    global_ctx = Path("~/.intellissh/contexts").expanduser()
    search_dirs = [global_ctx]
    extra = Path(ctx_dir).expanduser()
    if extra != global_ctx and extra.exists():
        search_dirs.append(extra)

    pattern = f"*{context_name}*"
    seen = set()
    matches = []
    for d in search_dirs:
        for f in sorted(d.rglob(pattern)):
            if f not in seen:
                seen.add(f)
                matches.append(f)

    if not matches:
        return "", []
    parts = []
    for f in matches:
        try:
            parts.append(f"### {f.name}\n\n{f.read_text(encoding='utf-8')}")
        except OSError:
            pass
    return "\n\n---\n\n".join(parts), matches


def cmd_ask(args):
    if not args:
        print(C.red("Usage: intellissh ask \"question\""))
        print(C.dim("       intellissh ask --context <name> \"question\"   # load specific context file"))
        print(C.dim("       intellissh ask --debug \"question\"             # show retrieved chunks (RAG)"))
        return

    debug = "--debug" in args
    args = [a for a in args if a != "--debug"]

    # --context flag overrides the global CONTEXT for this one-shot ask
    ask_context = CONTEXT
    if "--context" in args:
        idx = args.index("--context")
        if idx + 1 < len(args):
            ask_context = args[idx + 1]
            args = args[:idx] + args[idx + 2:]

    question = " ".join(args)
    config = load_config()

    try:
        import requests as req
    except ImportError:
        print(C.red("Missing: pip install requests"))
        sys.exit(1)

    # Context loading: direct file load (--context) or RAG fallback
    ctx = ""
    ctx_sources = []
    rag_error = None

    if ask_context:
        # Direct file load — no vector search needed
        ctx, matched_files = _load_context_files(ask_context, config.get("context_dir", str(BASE_DIR / "contexts")))
        if ctx:
            if debug:
                print(C.bold(C.cyan(f"\n── Context: {ask_context} ({len(matched_files)} file(s)) ──")))
                for f in matched_files:
                    print(C.dim(f"  {f.name}"))
                print()
        else:
            rag_error = f"No files matching '*{ask_context}*' in {config.get('context_dir')}"
            if debug:
                print(C.red(f"\n── Context error: {rag_error} ──\n"))
    elif not ask_context:
        # RAG retrieval (full corpus vector search)
        try:
            import chromadb
            db_path = Path(config.get("db_dir", "~/.intellissh/vectordb")).expanduser()
            if not db_path.exists():
                rag_error = f"Vector DB not found at {db_path} — run: intellissh index"
            else:
                client = chromadb.PersistentClient(path=str(db_path))

                def get_embedding(text):
                    em = config.get("embed_model", "nomic-embed-text")
                    try:
                        r = req.post(f"{config['ollama_url']}/api/embed",
                                     json={"model": em, "input": [text]}, timeout=120)
                        r.raise_for_status()
                        embs = r.json().get("embeddings", [])
                        if embs:
                            return embs[0]
                    except Exception:
                        pass
                    r2 = req.post(f"{config['ollama_url']}/api/embeddings",
                                  json={"model": em, "prompt": text}, timeout=120)
                    r2.raise_for_status()
                    return r2.json().get("embedding", [])

                col = client.get_collection("intellissh_contexts")
                count = col.count()
                if count == 0:
                    rag_error = "Index is empty — run: intellissh index"
                else:
                    q_emb = get_embedding(question)
                    res = col.query(query_embeddings=[q_emb], n_results=config.get("rag_top_k", 6),
                                    include=["documents", "metadatas", "distances"])
                    docs = res["documents"][0] if res["documents"][0] else []
                    metas = res["metadatas"][0] if res["metadatas"][0] else []
                    dists = res["distances"][0] if res["distances"][0] else []
                    min_sim = config.get("rag_min_similarity", 0.1)
                    if debug:
                        print(C.bold(C.cyan(f"\n── Raw retrieval ({count} chunks in index) ──")))
                        for i, (d, m, dist) in enumerate(zip(docs, metas, dists), 1):
                            sim = 1 - dist
                            flag = C.green("✓") if sim >= min_sim else C.red(f"✗ below min_sim={min_sim}")
                            print(C.dim(f"  [{i}] sim={sim:.3f} {flag}  {m.get('source','?')} › {m.get('section','?')}"))
                        print()
                    kept = [(d, m, 1 - dist) for d, m, dist in zip(docs, metas, dists)
                            if (1 - dist) >= min_sim]
                    ctx = "\n---\n".join(d for d, _, _ in kept)
                    ctx_sources = [(m.get("source", "?"), m.get("section", "?"), s)
                                   for _, m, s in kept]
        except Exception as e:
            rag_error = str(e)

    if debug and not ask_context:
        if rag_error:
            print(C.red(f"\n── RAG error: {rag_error} ──"))
        print(C.bold(C.cyan(f"\n── Retrieved {len(ctx_sources)} chunks (rag_top_k={config.get('rag_top_k', 6)}, min_sim={config.get('rag_min_similarity', 0.1)}) ──")))
        if ctx_sources:
            for i, (src, section, sim) in enumerate(ctx_sources, 1):
                print(C.dim(f"  [{i}] {src} › {section}  (similarity: {sim:.3f})"))
        else:
            print(C.red("  No chunks retrieved — model will answer from general knowledge only"))
        print()

    if not ctx:
        system = "You are IntelliSSH, a blue team security assistant. Be concise and direct."
    else:
        system = (
            "You are IntelliSSH, a blue team security assistant. "
            "Answer the question using ONLY the environment context provided below. "
            "Quote specific values (IPs, ports, parameters, commands) directly from the context. "
            "If the answer is not present in the context, say \"Not found in indexed documents\" "
            "— do not answer from general knowledge.\n\n"
            f"ENVIRONMENT CONTEXT:\n{ctx}"
        )

    payload = {
        "model": config.get("model", "qwen3:14b"),
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": f"/no_think\n{question}"},
        ],
        "stream": True,
    }

    r = req.post(f"{config['ollama_url']}/api/chat", json=payload, stream=True, timeout=300)
    for line in r.iter_lines(decode_unicode=True):
        if line:
            import json as j
            try:
                d = j.loads(line)
                c = d.get("message", {}).get("content", "")
                if c:
                    sys.stdout.write(c)
                    sys.stdout.flush()
            except j.JSONDecodeError:
                pass
    print()


# ─── Profiles ────────────────────────────────────────────────────────────────

def cmd_contexts(args):
    """List all contexts/profiles with their running status and dashboard URL."""
    print(C.bold("\nIntelliSSH Contexts"))
    print(C.dim("─" * 50))

    active_name = CONTEXT or PROFILE or "default"

    def _row(name, base_dir):
        running = _profile_is_running(base_dir)
        status = C.green("running") if running else C.dim("stopped")
        active = C.yellow(" ← active") if name == active_name else ""
        dashboard = ""
        if running:
            dashboard = C.dim(f"  {_get_dashboard_url(base_dir)}")
        print(f"  {C.cyan(name):<30} {status}{active}{dashboard}")

    _row("default", _resolve_base_dir(None))
    profiles_dir = Path("~/.intellissh/profiles").expanduser()
    if profiles_dir.exists():
        for p in sorted(profiles_dir.iterdir()):
            if p.is_dir():
                _row(p.name, p)
    print()
    print(C.dim("  Usage: intellissh --context <name> daemon   # isolated daemon + focused context"))
    print(C.dim("         export INTELLISSH_CONTEXT=<name>"))
    print(C.dim("  Note:  --profile is a legacy alias for --context"))
    print()


# ─── Main router ────────────────────────────────────────────────────────────

def print_usage():
    print(C.bold(C.cyan("IntelliSSH — AI-Augmented Blue Team Terminal\n")))
    print(f"  {C.cyan('intellissh daemon')}                        Start the AI daemon")
    print(f"  {C.cyan('intellissh daemon stop')}                   Stop the daemon")
    print(f"  {C.cyan('intellissh daemon -f')}                     Start in foreground (debug)")
    print(f"  {C.cyan('intellissh wrap ssh user@host')}            Wrap an SSH session")
    print(f"  {C.cyan('intellissh wrap bash')}                     Wrap a local shell")
    print(f"  {C.cyan('intellissh status')}                        Show daemon status")
    print(f"  {C.cyan('intellissh flush')}                         Reset all session state")
    print(f"  {C.cyan('intellissh contexts')}                      List all contexts")
    print(f"  {C.cyan('intellissh init')}                          Initialize context files")
    print(f"  {C.cyan('intellissh index')}                         Build RAG vector store")
    print(f"  {C.cyan('intellissh ask \"question\"')}                Quick one-shot question")
    print(f"  {C.cyan('intellissh ask --context <name> \"question\"')} Ask with specific context file")
    print()
    print(C.dim("  Context flag (isolate state + load focused knowledge per system):"))
    print(C.dim("    intellissh --context powergrid daemon"))
    print(C.dim("    intellissh --context powergrid wrap ssh analyst@10.0.0.1"))
    print(C.dim("    intellissh --context powergrid ask \"what is the nominal voltage?\""))
    print(C.dim("    export INTELLISSH_CONTEXT=powergrid   # set once per shell session"))
    print()
    print(C.dim("  During a wrapped session, press Ctrl+G to summon the AI."))


def main():
    if len(sys.argv) < 2:
        print_usage()
        sys.exit(0)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if cmd == "daemon":
        cmd_daemon(args)
    elif cmd == "wrap":
        cmd_wrap(args)
    elif cmd == "status":
        cmd_status(args)
    elif cmd == "init":
        cmd_init(args)
    elif cmd == "index":
        cmd_index(args)
    elif cmd == "ask":
        cmd_ask(args)
    elif cmd == "flush":
        cmd_flush(args)
    elif cmd in ("contexts", "profiles"):
        cmd_contexts(args)
    elif cmd in ("-h", "--help", "help"):
        print_usage()
    else:
        print(C.red(f"Unknown command: {cmd}"))
        print_usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
