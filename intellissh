#!/usr/bin/env python3
"""
intellissh — AI-Augmented Blue Team Terminal
=========================================
An AI-powered terminal wrapper that provides real-time situational awareness
during security defense training. Wraps SSH/shell sessions, captures all I/O,
and provides cross-session analysis via a local Ollama LLM + RAG.

Commands:
    intellissh daemon                Start the background AI daemon
    intellissh daemon stop           Stop the daemon
    intellissh wrap ssh user@host    Wrap an SSH session with AI augmentation
    intellissh wrap bash             Wrap a local shell
    intellissh init                  Initialize context files
    intellissh index [--force]       Build/rebuild the RAG vector store
    intellissh status                Show daemon status and active sessions
    intellissh flush                 Reset all session state (clean sheet)
    intellissh profiles              List all profiles with status
    intellissh ask "question"        Quick one-shot question (no wrapping)

Profile isolation (run two completely independent environments in parallel):
    intellissh --profile net1 daemon
    intellissh --profile net1 wrap ssh analyst@10.0.1.20
    export INTELLISSH_PROFILE=net1   # set once per shell session instead of --profile
"""

import sys
import os
import json
import signal
import subprocess
