# ─── Context / Profile & paths ───────────────────────────────────────────────

def _parse_flag(*flags):
    """Strip a flag and its value from sys.argv; return value or None."""
    val = None
    i = 1
    while i < len(sys.argv):
        if sys.argv[i] in flags and i + 1 < len(sys.argv):
            val = sys.argv[i + 1]
            sys.argv = sys.argv[:i] + sys.argv[i + 2:]
            break
        i += 1
    return val


# --context takes precedence; --profile is legacy alias for isolation-only use
CONTEXT = (_parse_flag("--context", "-c")
           or os.environ.get("INTELLISSH_CONTEXT", "").strip()
           or None)
PROFILE = (_parse_flag("--profile", "-p")
           or os.environ.get("INTELLISSH_PROFILE", "").strip()
           or None)

# Context drives isolation; fall back to profile if no context given
_ISOLATION = CONTEXT or PROFILE


def _resolve_base_dir(isolation):
    if not isolation:
        return Path("~/.intellissh").expanduser()
    safe = "".join(c for c in isolation if c.isalnum() or c in "_-")[:32]
    return Path(f"~/.intellissh/profiles/{safe}").expanduser()


BASE_DIR = _resolve_base_dir(_ISOLATION)
CONFIG_PATH = BASE_DIR / "config.json"
SOCKET_PATH = BASE_DIR / "daemon.sock"
PID_PATH = BASE_DIR / "daemon.pid"
DASHBOARD_PORT_FILE = BASE_DIR / "dashboard.port"
SCRIPT_DIR = Path(__file__).resolve().parent

